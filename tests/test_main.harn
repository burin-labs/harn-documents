import {
  artifact_manifest,
  artifact_manifest_digest,
  artifact_manifest_fallback,
  artifact_manifest_file_spec,
  artifact_manifest_mime_type,
  artifact_manifest_schema_url,
  artifact_manifest_schema_version,
  file_artifact_spec,
  normalize_file_artifact_spec,
  pandoc_docx_command,
  render_markdown_report,
  render_typst_report,
  report_bundle,
  typst_compile_command,
} from "../lib"

pipeline test_report_rendering(task) {
  const report = {
    title: "Code findings",
    subtitle: "Artifact report",
    summary: "File artifacts travel as references instead of raw payloads.",
    sections: [{heading: "Scope", body: "The runtime owns artifact transport."}],
    findings: [
      {
        severity: "high",
        title: "Raw document payloads should stay out of transcripts",
        path: "src/agent.harn",
        line: 42,
        evidence: ["artifact references are safe to persist"],
      },
    ],
  }
  const markdown = render_markdown_report(report)
  assert(contains(markdown, "# Code findings"))
  assert(contains(markdown, "**high** Raw document payloads should stay out of transcripts"))
  const typst = render_typst_report(report)
  assert(contains(typst, "#set document"))
  assert(contains(typst, "Code findings"))
  const bundle = report_bundle(report, "out/code-findings")
  assert_eq(bundle.pdf_path, "out/code-findings.pdf")
  assert_eq(bundle.artifacts[0].mime_type, "application/pdf")
}

pipeline test_renderer_commands(task) {
  assert_eq(
    typst_compile_command("report.typ", "report.pdf", {root: "workspace"}),
    ["typst", "compile", "report.typ", "report.pdf", "--root", "workspace"],
  )
  assert_eq(
    pandoc_docx_command("report.md", "report.docx", {reference_doc: "reference.docx"}),
    [
      "pandoc",
      "report.md",
      "--from",
      "gfm",
      "--to",
      "docx",
      "-o",
      "report.docx",
      "--reference-doc",
      "reference.docx",
    ],
  )
}

pipeline test_file_artifact_normalization(task) {
  const digest = "a".repeat(64)
  const spec = normalize_file_artifact_spec(
    {
      path: "out/report.pdf",
      mimeType: "application/pdf",
      size_bytes: 123,
      sha256: "sha256:" + digest,
    },
    "",
    {name: "report.pdf"},
  )
  assert_eq(spec.uri, "file://out/report.pdf")
  assert_eq(spec.path, "out/report.pdf")
  assert_eq(spec.name, "report.pdf")
  assert_eq(spec.mime_type, "application/pdf")
  assert_eq(spec.size_bytes, 123)
  assert_eq(spec.sha256, "sha256:" + digest)
}

pipeline test_artifact_manifest(task) {
  assert_eq(artifact_manifest_schema_version(), "harn.artifacts.v1")
  assert_eq(
    artifact_manifest_schema_url(),
    "https://harnlang.com/schemas/artifact-manifest.v1.schema.json",
  )
  assert_eq(artifact_manifest_mime_type(), "application/vnd.harn.artifact-manifest+json")
  const report = file_artifact_spec(
    "artifact://session/report.pdf",
    "application/pdf",
    {name: "report.pdf", size_bytes: 1024, sha256: "sha256:" + "b".repeat(64)},
  )
  const preview = file_artifact_spec(
    "artifact://session/preview.png",
    "image/png",
    {name: "preview.png", size_bytes: 512, sha256: "sha256:" + "c".repeat(64)},
  )
  const manifest = artifact_manifest([report, preview], {title: "Report bundle"})
  assert_eq(manifest.artifact_count, 2)
  assert_eq(manifest.total_size_bytes, 1536)
  assert(starts_with(artifact_manifest_digest(manifest), "sha256:"))
  assert(contains(artifact_manifest_fallback(manifest), "report.pdf (application/pdf, 1024 bytes)"))
  const manifest_spec = artifact_manifest_file_spec("out/manifest.json", manifest, {})
  assert_eq(manifest_spec.mime_type, artifact_manifest_mime_type())
  assert_eq(manifest_spec.name, "manifest.json")
  assert(starts_with(manifest_spec.sha256, "sha256:"))
}

pipeline test_harn_artifact_emit_receipts(task) {
  const report = file_artifact_spec(
    "artifact://session/report.pdf",
    "application/pdf",
    {name: "report.pdf", size_bytes: 1024, sha256: "sha256:" + "d".repeat(64)},
  )
  const manifest = artifact_manifest([report], {title: "Report bundle"})
  const file_receipt = artifact_emit(
    "file",
    report,
    {session_id: "harn-documents-test", artifact_id: "report-file"},
  )
  const manifest_receipt = artifact_emit(
    "artifact_manifest",
    manifest,
    {session_id: "harn-documents-test", artifact_id: "report-manifest"},
  )
  assert_eq(file_receipt.ok, true)
  assert_eq(file_receipt.artifact_id, "report-file")
  assert_eq(file_receipt.kind, "file")
  assert_eq(file_receipt.mime_type, "application/pdf")
  assert_eq(manifest_receipt.ok, true)
  assert_eq(manifest_receipt.artifact_id, "report-manifest")
  assert_eq(manifest_receipt.kind, "artifact_manifest")
  assert_eq(manifest_receipt.mime_type, artifact_manifest_mime_type())
}
