import {
  artifact_manifest,
  artifact_manifest_digest,
  artifact_manifest_emit_args,
  artifact_manifest_fallback,
  artifact_manifest_file_spec,
  artifact_manifest_mime_type,
  artifact_manifest_schema_url,
  artifact_manifest_schema_version,
  artifact_manifest_session_update,
  artifact_session_update,
  artifact_session_updates_ndjson,
  file_artifact_spec,
  managed_agent_artifact_content_path,
  managed_agent_artifact_content_request,
  managed_agent_artifact_get_request,
  managed_agent_artifact_kind,
  managed_agent_artifact_list_query,
  managed_agent_artifact_list_request,
  managed_agent_artifact_manifest_register_body,
  managed_agent_artifact_path,
  managed_agent_artifact_register_body,
  managed_agent_artifact_register_request,
  managed_agent_artifacts_path,
  normalize_file_artifact_spec,
  pandoc_docx_command,
  render_markdown_report,
  render_typst_report,
  report_bundle,
  typst_compile_command,
} from "../lib"

pipeline test_artifact_manifest_contract_metadata(task) {
  assert_eq(artifact_manifest_schema_version(), "harn.artifacts.v1")
  assert_eq(
    artifact_manifest_schema_url(),
    "https://harnlang.com/schemas/artifact-manifest.v1.schema.json",
  )
  assert_eq(artifact_manifest_mime_type(), "application/vnd.harn.artifact-manifest+json")
}

pipeline test_report_rendering(task) {
  let report = {
    title: "Code findings",
    subtitle: "Burin/Harn artifact slice",
    summary: "File artifacts now travel as references instead of raw payloads.",
    sections: [{heading: "Scope", body: "Harn owns generic artifact semantics; Burin owns product UI."}],
    findings: [
      {
        severity: "high",
        title: "Raw document payloads should stay out of transcripts",
        path: "Sources/Agent.swift",
        line: 42,
        evidence: ["artifact refs are safer to persist"],
      },
    ],
  }
  let markdown = render_markdown_report(report)
  assert(contains(markdown, "# Code findings"))
  assert(contains(markdown, "## Findings"))
  assert(contains(markdown, "**high** Raw document payloads should stay out of transcripts"))
  let typst = render_typst_report(report)
  assert(contains(typst, "#set document"))
  assert(contains(typst, "Code findings"))
  let pdf_command = typst_compile_command("report.typ", "report.pdf", {})
  assert_eq(pdf_command, ["typst", "compile", "report.typ", "report.pdf"])
  let docx_command = pandoc_docx_command("report.md", "report.docx", {})
  assert_eq(docx_command[0], "pandoc")
  assert_eq(docx_command[5], "docx")
  let bundle = report_bundle(report, "/tmp/code-findings")
  assert_eq(bundle.pdf_path, "/tmp/code-findings.pdf")
  assert(contains(bundle.markdown, "Burin/Harn artifact slice"))
  assert_eq(bundle.artifacts[0].mime_type, "application/pdf")
}

pipeline test_file_artifact_spec(task) {
  let spec = file_artifact_spec(
    "/tmp/report.pdf",
    "application/pdf",
    {
      name: "report.pdf",
      size_bytes: 123,
      sha256: "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
      description: "Code findings report",
    },
  )
  assert_eq(spec.uri, "file:///tmp/report.pdf")
  assert_eq(spec.name, "report.pdf")
  assert_eq(spec.mime_type, "application/pdf")
  assert_eq(spec.size_bytes, 123)
  assert_eq(spec.sha256, "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef")
}

pipeline test_artifact_manifest_and_session_updates(task) {
  let pdf = normalize_file_artifact_spec(
    {
      path: "/tmp/report.pdf",
      mimeType: "application/pdf",
      size_bytes: 1024,
      sha256: "sha256:" + "a".repeat(64),
      description: "Code findings PDF",
    },
    "",
    {},
  )
  assert_eq(pdf.uri, "file:///tmp/report.pdf")
  assert_eq(pdf.mime_type, "application/pdf")
  assert_eq(pdf.size_bytes, 1024)
  let png = file_artifact_spec(
    "artifact://session/chart.png",
    "image/png",
    {name: "chart.png", size_bytes: 512, sha256: "sha256:" + "b".repeat(64)},
  )
  let manifest = artifact_manifest(
    [pdf, png],
    {
      title: "Dogfood artifacts",
      session_id: "ses_123",
      run_id: "run_456",
      created_at: "2026-07-05T00:00:00Z",
    },
  )
  assert_eq(manifest.schema_version, artifact_manifest_schema_version())
  assert_eq(manifest.artifact_count, 2)
  assert_eq(manifest.total_size_bytes, 1536)
  assert_eq(manifest.artifacts[0].name, "report.pdf")
  assert_eq(manifest.artifacts[1].uri, "artifact://session/chart.png")
  assert(starts_with(artifact_manifest_digest(manifest), "sha256:"))
  let manifest_spec = artifact_manifest_file_spec("/tmp/manifest.json", manifest, {})
  assert_eq(manifest_spec.mime_type, artifact_manifest_mime_type())
  assert_eq(manifest_spec.name, "manifest.json")
  assert(starts_with(manifest_spec.sha256, "sha256:"))
  let fallback = artifact_manifest_fallback(manifest)
  assert(contains(fallback, "Dogfood artifacts: 2 file artifact(s)"))
  assert(contains(fallback, "report.pdf (application/pdf, 1024 bytes)"))
  let manifest_update = artifact_manifest_session_update(manifest, {artifact_id: "artifact-manifest"})
  assert_eq(manifest_update.sessionUpdate, "artifact")
  assert_eq(manifest_update._meta.harn.artifactId, "artifact-manifest")
  assert_eq(manifest_update._meta.harn.kind, "artifact_manifest")
  assert_eq(manifest_update._meta.harn.mimeType, artifact_manifest_mime_type())
  assert_eq(manifest_update._meta.harn.spec.schema_version, artifact_manifest_schema_version())
  assert_eq(manifest_update._meta.harn.metadata.schema_url, artifact_manifest_schema_url())
  assert(starts_with(manifest_update._meta.harn.metadata.digest, "sha256:"))
  let emit_args = artifact_manifest_emit_args(manifest, {session_id: "ses_123", max_bytes: 12345})
  assert_eq(emit_args.kind, "artifact_manifest")
  assert_eq(emit_args.spec.artifact_count, 2)
  assert_eq(emit_args.options.session_id, "ses_123")
  assert_eq(emit_args.options.max_bytes, 12345)
  assert(starts_with(emit_args.options.artifact_id, "manifest-"))
  let update = artifact_session_update(pdf, {artifact_id: "artifact-report", title: "Report PDF"})
  assert_eq(update.sessionUpdate, "artifact")
  assert_eq(update._meta.harn.artifactId, "artifact-report")
  assert_eq(update._meta.harn.kind, "file")
  assert_eq(update._meta.harn.title, "Report PDF")
  assert_eq(update._meta.harn.mimeType, "application/pdf")
  assert_eq(update._meta.harn.sizeBytes, 1024)
  assert_eq(update._meta.harn.spec.uri, "file:///tmp/report.pdf")
  let ndjson = artifact_session_updates_ndjson([pdf, png], {metadata: {source: "test"}})
  assert(contains(ndjson, "\"sessionUpdate\":\"artifact\""))
  assert(contains(ndjson, "\"_meta\":{\"harn\""))
  assert(contains(ndjson, "\"mimeType\":\"image/png\""))
}

pipeline test_managed_agent_artifact_api_helpers(task) {
  assert_eq(managed_agent_artifacts_path(), "/v1/artifacts")
  let pdf = file_artifact_spec(
    "/tmp/report.pdf",
    "application/pdf",
    {
      name: "report.pdf",
      size_bytes: 4096,
      sha256: "sha256:" + "c".repeat(64),
      description: "Code findings PDF",
    },
  )
  let body = managed_agent_artifact_register_body(
    pdf,
    {
      visibility: "internal",
      workspace_id: "workspace_123",
      session_id: "session_123",
      task_id: "task_123",
      title: "Findings report",
      metadata: {source: "unit-test"},
    },
  )
  assert_eq(body.kind, "file")
  assert_eq(body.mime_type, "application/pdf")
  assert_eq(body.uri, "file:///tmp/report.pdf")
  assert_eq(body.visibility, "internal")
  assert_eq(body.sha256, "c".repeat(64))
  assert_eq(body.size_bytes, 4096)
  assert_eq(body.name, "report.pdf")
  assert_eq(body.title, "Findings report")
  assert_eq(body.workspace_id, "workspace_123")
  assert_eq(body.session_id, "session_123")
  assert_eq(body.task_id, "task_123")
  assert_eq(body.metadata.source, "unit-test")
  assert_eq(body.metadata.description, "Code findings PDF")
  let register = managed_agent_artifact_register_request(pdf, {visibility: "public"})
  assert_eq(register.method, "POST")
  assert_eq(register.path, "/v1/artifacts")
  assert_eq(register.scopes, ["artifacts:write"])
  assert_eq(register.body.visibility, "public")
  let query = managed_agent_artifact_list_query({workspace_id: "workspace_123", limit: 50})
  assert_eq(query.workspace_id, "workspace_123")
  assert_eq(query.limit, 50)
  let list = managed_agent_artifact_list_request({task_id: "task_123"})
  assert_eq(list.method, "GET")
  assert_eq(list.path, "/v1/artifacts")
  assert_eq(list.scopes, ["artifacts:read"])
  assert_eq(list.query.task_id, "task_123")
  assert_eq(managed_agent_artifact_path("artifact/id"), "/v1/artifacts/artifact%2Fid")
  assert_eq(managed_agent_artifact_content_path("artifact/id"), "/v1/artifacts/artifact%2Fid/content")
  assert_eq(managed_agent_artifact_get_request("artifact_123", {}).path, "/v1/artifacts/artifact_123")
  assert_eq(
    managed_agent_artifact_content_request("artifact_123", {}).path,
    "/v1/artifacts/artifact_123/content",
  )
}

pipeline test_managed_agent_artifact_kind_and_manifest_body(task) {
  assert_eq(managed_agent_artifact_kind({mime_type: "image/png", name: "plot.png"}, {}), "image")
  assert_eq(managed_agent_artifact_kind({mime_type: "text/plain", name: "run.log"}, {}), "log")
  assert_eq(managed_agent_artifact_kind({mime_type: "text/csv", name: "table.csv"}, {}), "dataset")
  assert_eq(managed_agent_artifact_kind({mime_type: "text/plain", name: "change.diff"}, {}), "diff")
  assert_eq(managed_agent_artifact_kind({mime_type: "text/plain", name: "change.patch"}, {}), "patch")
  assert_eq(
    managed_agent_artifact_kind({mime_type: "application/pdf", name: "report.pdf"}, {}),
    "file",
  )
  let report = file_artifact_spec(
    "artifact://session/report.pdf",
    "application/pdf",
    {name: "report.pdf", size_bytes: 1024, sha256: "sha256:" + "a".repeat(64)},
  )
  let manifest = artifact_manifest([report], {title: "Managed report bundle"})
  let body = managed_agent_artifact_manifest_register_body(
    manifest,
    "artifact://session/artifact-manifest.json",
    {session_id: "session_123"},
  )
  assert_eq(body.kind, "receipt")
  assert_eq(body.mime_type, artifact_manifest_mime_type())
  assert_eq(body.uri, "artifact://session/artifact-manifest.json")
  assert_eq(body.visibility, "receipt_only")
  assert_eq(body.session_id, "session_123")
  assert_eq(body.metadata.schema_url, artifact_manifest_schema_url())
  assert_eq(body.metadata.digest, artifact_manifest_digest(manifest))
  assert_eq(body.sha256, replace(artifact_manifest_digest(manifest), "sha256:", ""))
}
